ESLINT_NO_DEV_ERRORS=true

# Auth toggle — use `make auth_enable` / `make auth_disable` to switch.
DEVELOPMENT_ONLY_REQUIRE_AUTH=false

# CSRF / cookie security. Set to false when serving over plain HTTP (local dev).
# CSRF_COOKIE_SECURE=true
# CSRF_COOKIE_SAMESITE=Strict
# CSRF_CHECK_REFERER=true
# CSRF_DISABLE=false

# Optional service tokens — leave empty to disable the feature in development.
SLACK_OAUTH_BOT_TOKEN=

# Optional cartography tokens — only needed when running the cartography profile.
CARTOGRAPHY_GITHUB_TOKEN=
CROWDSTRIKE_CLIENT_ID=
CROWDSTRIKE_CLIENT_SECRET=
PAGERDUTY_API_KEY=
OKTA_API_KEY=

# Neo4j notification severity (WARNING, INFORMATION, OFF).
# Set to OFF to suppress schema warnings when the database is not fully populated.
# NEO4J_NOTIFICATIONS_MIN_SEVERITY=WARNING

# Report storage backend. Supported: dynamodb (default), sqlmodel.
REPORT_STORE_BACKEND=dynamodb

# SQLModel database URL (used when REPORT_STORE_BACKEND=sqlmodel).
# Any SQLAlchemy-compatible URL: postgresql://, sqlite:///, etc.
# In development the docker-compose.yml pre-configures the postgres container URL.
# SQL_DATABASE_URL=postgresql://seizu:seizu@postgres:5432/seizu

# DynamoDB report config storage.
# In development these are set automatically via docker-compose.yml.
# Override here only if you need non-default values (e.g. a real AWS table).
# DYNAMODB_TABLE_NAME=seizu-reports
# DYNAMODB_REGION=us-east-1
# DYNAMODB_ENDPOINT_URL=
# DYNAMODB_CREATE_TABLE=false
# SNOWFLAKE_MACHINE_ID=1

# MCP server at /api/v1/mcp. Disable to turn off the endpoint entirely.
# MCP_ENABLED=true

# OAuth 2.0 metadata for MCP clients (enables in-client auth, e.g. Claude Desktop).
# Set to your OIDC provider's authorization and token endpoints.
# Authentik example:
# MCP_OAUTH_AUTHORIZATION_ENDPOINT=https://authentik.example.com/application/o/seizu/authorize/
# MCP_OAUTH_TOKEN_ENDPOINT=https://authentik.example.com/application/o/token/
# MCP_OAUTH_ISSUER=https://authentik.example.com/application/o/seizu/
# (MCP_OAUTH_ISSUER defaults to JWT_ISSUER if unset)
