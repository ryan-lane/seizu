ESLINT_NO_DEV_ERRORS=true

# Auth toggle — use `make auth_enable` / `make auth_disable` to switch.
DEVELOPMENT_ONLY_REQUIRE_AUTH=false

# Optional service tokens — leave empty to disable the feature in development.
SLACK_OAUTH_BOT_TOKEN=

# Optional cartography tokens — only needed when running the cartography profile.
CARTOGRAPHY_GITHUB_TOKEN=
CROWDSTRIKE_CLIENT_ID=
CROWDSTRIKE_CLIENT_SECRET=
PAGERDUTY_API_KEY=
OKTA_API_KEY=

# APOC plugin toggle — use `make apoc_enable` / `make apoc_disable` to switch.
# When enabled, Neo4j downloads the matching APOC version on first start (requires internet).
NEO4J_PLUGINS=

# Neo4j notification severity (WARNING, INFORMATION, OFF).
# Set to OFF to suppress schema warnings when the database is not fully populated.
# NEO4J_NOTIFICATIONS_MIN_SEVERITY=WARNING

# Report storage backend. Supported: dynamodb (default), sqlmodel.
REPORT_STORE_BACKEND=dynamodb

# SQLModel database URL (used when REPORT_STORE_BACKEND=sqlmodel).
# Any SQLAlchemy-compatible URL: postgresql://, sqlite:///, etc.
# In development the docker-compose.yml pre-configures the postgres container URL.
# SQL_DATABASE_URL=postgresql://seizu:seizu@postgres:5432/seizu

# DynamoDB report config storage.
# In development these are set automatically via docker-compose.yml.
# Override here only if you need non-default values (e.g. a real AWS table).
# DYNAMODB_TABLE_NAME=seizu-reports
# DYNAMODB_REGION=us-east-1
# DYNAMODB_ENDPOINT_URL=
# DYNAMODB_CREATE_TABLE=false
# SNOWFLAKE_MACHINE_ID=1

# RBAC settings.
# JWT claim that contains the user's Seizu role name.
# Configure your OIDC provider to embed the role directly as a claim (e.g. "seizu-admin").
# RBAC_ROLE_CLAIM=seizu_role
#
# Default role when the user's JWT has no RBAC_ROLE_CLAIM.
# Valid values: "seizu-viewer", "seizu-editor", "seizu-admin", or any user-defined role name.
# Set to "" to deny access to users without an explicit role claim.
# RBAC_DEFAULT_ROLE=seizu-viewer

# MCP server at /api/v1/mcp. Disable to turn off the endpoint entirely.
# MCP_ENABLED=true

# Which built-in MCP tool groups to expose. User-defined toolsets are always available.
# Unset or empty: all groups enabled (default).
# "none": disable all built-in groups.
# Comma-separated list: only those groups (e.g. "graph,reports").
# Known groups: graph, reports, scheduled_queries, toolsets, roles.
# MCP_ENABLED_BUILTINS=graph,reports,scheduled_queries,toolsets,roles

# OAuth 2.0 metadata for MCP clients (enables in-client auth, e.g. Claude Desktop).
# Set to your OIDC provider's authorization and token endpoints.
# Authentik example:
# MCP_OAUTH_AUTHORIZATION_ENDPOINT=https://authentik.example.com/application/o/seizu/authorize/
# MCP_OAUTH_TOKEN_ENDPOINT=https://authentik.example.com/application/o/token/
# MCP_OAUTH_ISSUER=https://authentik.example.com/application/o/seizu/
# (MCP_OAUTH_ISSUER defaults to JWT_ISSUER if unset)
# Public base URL of the MCP endpoint — required for RFC 9728 protected resource
# discovery and the WWW-Authenticate resource_metadata header.
# MCP_RESOURCE_URL=https://seizu.example.com/api/v1/mcp
# Internal authority URL used by the server for OIDC discovery. Defaults to
# OIDC_AUTHORITY; set this when the server cannot reach the public OIDC_AUTHORITY
# (e.g. environments with split internal/external hostnames).
# OIDC_INTERNAL_AUTHORITY=https://internal-idp.example.com/application/o/seizu/
# Override the dynamic client registration (RFC 7591) endpoint in OAuth metadata.
# When unset, Seizu serves its own built-in endpoint that returns OIDC_CLIENT_ID,
# which satisfies MCP clients (e.g. Claude Desktop) that require DCR support.
# MCP_OAUTH_REGISTRATION_ENDPOINT=
