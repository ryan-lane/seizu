    "properties": {
        "queries": {
            "additionalProperties": {
                "type": "string"
            },
            "description": "The queries to use for the report.",
            "examples": [
                "\n            .. code-block:: yaml\n\n              queries:\n                cves-severity-of-total: |-\n                  MATCH (c:CVE)\n                  WITH COUNT(DISTINCT c.id) AS denominator\n                  MATCH (c:CVE)\n                  WHERE c.base_severity = \"CRITICAL\"\n                  RETURN count(DISTINCT c.id) AS numerator, denominator\n            "
            ],
            "title": "Queries",
            "type": "object"
        },
        "dashboard": {
            "anyOf": [
                {
                    "type": "string"
                },
                {
                    "type": "null"
                }
            ],
            "default": null,
            "description": "Key of the report in the ``reports`` section to use as the default dashboard. If unset, no report is displayed on the dashboard page.",
            "examples": [
                "dashboard"
            ],
            "title": "Dashboard"
        },
        "reports": {
            "additionalProperties": {
                "$ref": "#/$defs/Report"
            },
            "description": "The reports to use for the report.",
            "examples": [
                "\n            .. code-block:: yaml\n\n              reports:\n                cves:\n                  name: CVEs\n                  rows:\n                    - name: CVEs\n                      panels:\n                        - cypher: cves\n                          type: table\n                          size: 12\n            "
            ],
            "title": "Reports",
            "type": "object"
        },
        "scheduled_queries": {
            "description": "The scheduled queries to run.",
            "examples": [
                "\n            .. code-block:: yaml\n\n              scheduled_queries:\n                - name: CVEs by severity\n                  cypher: recent-cves\n                  frequency: 1440\n                  actions:\n                    - action_type: slack\n                      action_config:\n                        title: Recently published HIGH/CRITICAL CVEs\n            "
            ],
            "items": {
                "$ref": "#/$defs/ScheduledQuery"
            },
            "title": "Scheduled Queries",
            "type": "array"
        },
        "toolsets": {
            "additionalProperties": {
                "$ref": "#/$defs/ToolsetDef"
            },
            "description": "Toolset definitions for MCP tool exposure.",
            "examples": [
                "\n            .. code-block:: yaml\n\n              toolsets:\n                my-toolset:\n                  name: My Toolset\n                  description: A collection of graph tools\n                  enabled: true\n                  tools:\n                    my-tool:\n                      name: My Tool\n                      description: Counts nodes\n                      cypher: MATCH (n) RETURN count(n) AS total\n                      enabled: true\n            "
            ],
            "title": "Toolsets",
            "type": "object"
        },
        "skillsets": {
            "additionalProperties": {
                "$ref": "#/$defs/SkillsetDef"
            },
            "description": "Skillset definitions for MCP prompt exposure.",
            "examples": [
                "\n            .. code-block:: yaml\n\n              skillsets:\n                investigations:\n                  name: Investigations\n                  description: Prompt templates for graph investigations\n                  enabled: true\n                  skills:\n                    summarize_node:\n                      name: Summarize node\n                      template: Summarize {{node_id}} for a security analyst.\n                      parameters:\n                        - name: node_id\n                          type: string\n            "
            ],
            "title": "Skillsets",
            "type": "object"
        }
    },
