{
    "$defs": {
        "BarPanelSettings": {
            "properties": {
                "legend": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "The type of legend to use; ``row`` or ``column``. If unset, then no legend will be used.",
                    "title": "Legend"
                }
            },
            "title": "BarPanelSettings",
            "type": "object"
        },
        "GraphPanelSettings": {
            "properties": {
                "node_label": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "The node property to display as the node label. Defaults to ``label`` if unset.",
                    "title": "Node Label"
                },
                "node_color_by": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "The node property to use for color grouping. Defaults to ``group`` if unset.",
                    "title": "Node Color By"
                }
            },
            "title": "GraphPanelSettings",
            "type": "object"
        },
        "Input": {
            "properties": {
                "input_id": {
                    "description": "Reference to the query in the inputs section.",
                    "examples": [
                        "cve_base_severity"
                    ],
                    "title": "Input Id",
                    "type": "string"
                },
                "label": {
                    "description": "The label to use for the select element.",
                    "examples": [
                        "CVE base severity"
                    ],
                    "title": "Label",
                    "type": "string"
                },
                "type": {
                    "description": "The type of input to use.",
                    "enum": [
                        "autocomplete",
                        "text"
                    ],
                    "examples": [
                        "autocomplete"
                    ],
                    "title": "Type",
                    "type": "string"
                },
                "cypher": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "The Cypher query to execute. Must return ``value``.",
                    "examples": [
                        "\n            .. code-block:: cypher\n\n              MATCH (c:CVE)\n              RETURN DISTINCT c.base_severity AS value\n            "
                    ],
                    "title": "Cypher"
                },
                "default": {
                    "anyOf": [
                        {
                            "$ref": "#/$defs/InputDefault"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "The default value to set if no value is selected.",
                    "examples": [
                        "\n            .. code-block:: yaml\n\n              label: (all)\n              value: .*\n            "
                    ]
                },
                "size": {
                    "anyOf": [
                        {
                            "type": "integer"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": 2,
                    "description": "The size of the input element.",
                    "examples": [
                        "2"
                    ],
                    "title": "Size"
                }
            },
            "required": [
                "input_id",
                "label",
                "type"
            ],
            "title": "Input",
            "type": "object"
        },
        "InputDefault": {
            "properties": {
                "label": {
                    "description": "The label for the default.",
                    "title": "Label",
                    "type": "string"
                },
                "value": {
                    "description": "The value for the default.",
                    "title": "Value",
                    "type": "string"
                }
            },
            "required": [
                "label",
                "value"
            ],
            "title": "InputDefault",
            "type": "object"
        },
        "Panel": {
            "properties": {
                "type": {
                    "description": "The type of panel to use.",
                    "enum": [
                        "table",
                        "vertical-table",
                        "count",
                        "bar",
                        "pie",
                        "graph",
                        "progress",
                        "markdown"
                    ],
                    "examples": [
                        "table"
                    ],
                    "title": "Type",
                    "type": "string"
                },
                "cypher": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "A reference to a cypher from the cypher section of the configuration.",
                    "examples": [
                        "cves"
                    ],
                    "title": "Cypher"
                },
                "details_cypher": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "A reference to a cypher from the cypher section of the configuration. Used in the details section of the panel, as a table. The query can return rows in any of the formats supported by the ``table`` panel type.",
                    "examples": [
                        "cves-details"
                    ],
                    "title": "Details Cypher"
                },
                "params": {
                    "description": "A list of parameters to send into the query. The parameters can directly have values, or can be a reference to an input.",
                    "examples": [
                        "\n            .. code-block:: yaml\n\n              params:\n                - name: severity\n                  input_id: cve_base_severity\n                - name: integrityImpact\n                  value: HIGH\n            "
                    ],
                    "items": {
                        "$ref": "#/$defs/PanelParam"
                    },
                    "title": "Params",
                    "type": "array"
                },
                "caption": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "The caption to use for the panel.",
                    "examples": [
                        "Critical CVEs"
                    ],
                    "title": "Caption"
                },
                "table_id": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "The cypher attribute to use for the table's unique ID, if using a type of table or vertical-table. If not set, a random ID will be generated. A table_id should be set for ``vertical-table``, or the panel will have a random ID used as the caption.",
                    "examples": [
                        "cve_id"
                    ],
                    "title": "Table Id"
                },
                "markdown": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "The markdown to use for the panel. Only used for type ``markdown``.",
                    "examples": [
                        "\n            .. code-block:: markdown\n\n                ## Affects\n\n                Versions x.x.x - x.x.x\n\n                ## Recommended action\n\n                Upgrade to the latest version of the software.\n            "
                    ],
                    "title": "Markdown"
                },
                "size": {
                    "anyOf": [
                        {
                            "type": "integer"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": 2,
                    "description": "The legacy width of the panel as MUI grid columns (1-12). When ``w`` is set, ``w`` takes precedence. Retained for back-compat with reports authored before per-panel height support.",
                    "examples": [
                        "2"
                    ],
                    "title": "Size"
                },
                "w": {
                    "anyOf": [
                        {
                            "type": "integer"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "The width of the panel in grid columns (1-12). Supersedes ``size`` when set. Used by react-grid-layout.",
                    "examples": [
                        "3"
                    ],
                    "title": "W"
                },
                "h": {
                    "anyOf": [
                        {
                            "type": "integer"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "The height of the panel in grid row units (each row is 48px). When unset, the frontend derives a sensible default per panel type.",
                    "examples": [
                        "8"
                    ],
                    "title": "H"
                },
                "x": {
                    "anyOf": [
                        {
                            "type": "integer"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "The column index (0-based) within the row's grid. When unset, the frontend packs panels left-to-right automatically.",
                    "examples": [
                        "0"
                    ],
                    "title": "X"
                },
                "y": {
                    "anyOf": [
                        {
                            "type": "integer"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "The row index within the row's grid. Always 0 for single-row layouts; reserved for future multi-row use.",
                    "examples": [
                        "0"
                    ],
                    "title": "Y"
                },
                "min_h": {
                    "anyOf": [
                        {
                            "type": "integer"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "Optional minimum height in grid row units. Enforced by react-grid-layout when the user resizes the panel.",
                    "examples": [
                        "4"
                    ],
                    "title": "Min H"
                },
                "auto_height": {
                    "anyOf": [
                        {
                            "type": "boolean"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "When ``True``, the panel renders at its natural content height instead of filling its grid cell. Only meaningful for ``markdown`` and ``vertical-table`` panel types; ignored elsewhere.",
                    "examples": [
                        "true"
                    ],
                    "title": "Auto Height"
                },
                "threshold": {
                    "anyOf": [
                        {
                            "type": "number"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "(Legacy) Single threshold value for ``count`` / ``progress`` panels. New configs should use ``thresholds``; this field is retained as a fallback when ``thresholds`` is unset.",
                    "examples": [
                        "70"
                    ],
                    "title": "Threshold"
                },
                "thresholds": {
                    "anyOf": [
                        {
                            "items": {
                                "$ref": "#/$defs/PanelThreshold"
                            },
                            "type": "array"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "Ordered list of ``{value, color}`` pairs for ``count`` and ``progress`` panels. The applicable color is the color of the threshold with the highest ``value`` that is less than or equal to the metric (raw total for ``count``, completion percentage for ``progress``). When unset, falls back to the legacy ``threshold`` field.",
                    "examples": [
                        "\n            .. code-block:: yaml\n\n              thresholds:\n                - value: 0\n                  color: \"#F44336\"\n                - value: 70\n                  color: \"#4CAF50\"\n            "
                    ],
                    "title": "Thresholds"
                },
                "bar_settings": {
                    "anyOf": [
                        {
                            "$ref": "#/$defs/BarPanelSettings"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "Settings specific to bar panels.",
                    "examples": [
                        "\n            .. code-block:: yaml\n\n              bar_settings:\n                legend: column\n            "
                    ]
                },
                "pie_settings": {
                    "anyOf": [
                        {
                            "$ref": "#/$defs/PiePanelSettings"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "Settings specific to pie panels.",
                    "examples": [
                        "\n            .. code-block:: yaml\n\n              pie_settings:\n                legend: column\n            "
                    ]
                },
                "graph_settings": {
                    "anyOf": [
                        {
                            "$ref": "#/$defs/GraphPanelSettings"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "Settings specific to graph panels.",
                    "examples": [
                        "\n            .. code-block:: yaml\n\n              graph_settings:\n                node_label: label\n                node_color_by: group\n            "
                    ]
                },
                "progress_settings": {
                    "anyOf": [
                        {
                            "$ref": "#/$defs/ProgressPanelSettings"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "Settings specific to progress panels.",
                    "examples": [
                        "\n            .. code-block:: yaml\n\n              progress_settings:\n                show_label: false\n            "
                    ]
                }
            },
            "required": [
                "type"
            ],
            "title": "Panel",
            "type": "object"
        },
        "PanelParam": {
            "properties": {
                "name": {
                    "description": "The parameter name to use when passing this input into the query.",
                    "examples": [
                        "severity"
                    ],
                    "title": "Name",
                    "type": "string"
                },
                "input_id": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "Reference to the query in the inputs section.",
                    "examples": [
                        "cve_base_severity"
                    ],
                    "title": "Input Id"
                },
                "value": {
                    "anyOf": [
                        {},
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "The parameter value to pass into the query.",
                    "examples": [
                        "\n            .. code-block:: yaml\n\n              params:\n                - name: integrityImpact\n                  value: HIGH\n            "
                    ],
                    "title": "Value"
                }
            },
            "required": [
                "name"
            ],
            "title": "PanelParam",
            "type": "object"
        },
        "PanelThreshold": {
            "properties": {
                "value": {
                    "description": "The threshold trigger value. For ``count`` panels, the metric is the raw total. For ``progress`` panels, the metric is the completion percentage (0-100).",
                    "examples": [
                        70
                    ],
                    "title": "Value",
                    "type": "number"
                },
                "color": {
                    "description": "The color to apply when the metric matches this threshold. A CSS color string (e.g. ``#F44336``, ``red``).",
                    "examples": [
                        "#F44336"
                    ],
                    "title": "Color",
                    "type": "string"
                }
            },
            "required": [
                "value",
                "color"
            ],
            "title": "PanelThreshold",
            "type": "object"
        },
        "PiePanelSettings": {
            "properties": {
                "legend": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "The type of legend to use; ``row`` or ``column``. If unset, then no legend will be used, and arc labels will be used instead.",
                    "title": "Legend"
                }
            },
            "title": "PiePanelSettings",
            "type": "object"
        },
        "ProgressPanelSettings": {
            "properties": {
                "show_label": {
                    "anyOf": [
                        {
                            "type": "boolean"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "Whether to render the ``numerator / denominator`` label above the progress wheel. Defaults to ``True`` when unset; pass ``False`` to hide the label and show only the wheel and percentage.",
                    "title": "Show Label"
                }
            },
            "title": "ProgressPanelSettings",
            "type": "object"
        },
        "Report": {
            "properties": {
                "schema_version": {
                    "default": 1,
                    "description": "The schema version of the report config. Increment when making breaking changes to the report schema.",
                    "examples": [
                        1
                    ],
                    "title": "Schema Version",
                    "type": "integer"
                },
                "name": {
                    "description": "The name of the report.",
                    "examples": [
                        "CVEs"
                    ],
                    "title": "Name",
                    "type": "string"
                },
                "queries": {
                    "additionalProperties": {
                        "type": "string"
                    },
                    "description": "Named Cypher queries for this report. Panel ``cypher`` fields may reference a key from this dict, or provide a Cypher query string directly.",
                    "examples": [
                        "\n            .. code-block:: yaml\n\n              queries:\n                cves-total: |-\n                  MATCH (c:CVE)\n                  RETURN count(c.id) AS total\n            "
                    ],
                    "title": "Queries",
                    "type": "object"
                },
                "inputs": {
                    "description": "The inputs to use for the report.",
                    "examples": [
                        "\n            .. code-block:: yaml\n\n              inputs:\n                - input_id: cve_base_severity\n                  cypher: |-\n                    MATCH (c:CVE)\n                    RETURN c.base_severity AS base_severity\n                  default:\n                    label: (all)\n                    value: .*\n                  label: Base Severity\n                  type: autocomplete\n                  size: 2\n            "
                    ],
                    "items": {
                        "$ref": "#/$defs/Input"
                    },
                    "title": "Inputs",
                    "type": "array"
                },
                "rows": {
                    "description": "The rows of the report.",
                    "examples": [
                        "\n            .. code-block:: yaml\n\n              rows:\n                - name: \"CVEs\"\n                  panels:\n                    - cypher: cves\n                      type: table\n                      params:\n                        - name: severity\n                          input_id: cve_base_severity\n                      size: 12\n            "
                    ],
                    "items": {
                        "$ref": "#/$defs/Row"
                    },
                    "title": "Rows",
                    "type": "array"
                }
            },
            "required": [
                "name"
            ],
            "title": "Report",
            "type": "object"
        },
        "Row": {
            "properties": {
                "name": {
                    "description": "The name of the row; shown as title above the row.",
                    "examples": [
                        "CVEs"
                    ],
                    "title": "Name",
                    "type": "string"
                },
                "panels": {
                    "description": "The panels to show in the row.",
                    "examples": [
                        "\n            .. code-block:: yaml\n\n              panels:\n                - cypher: cves-by-severity\n                  details_cypher: cves-by-severity-details\n                  type: count\n                  params:\n                    base_severity: CRITICAL\n                  caption: Critical CVEs\n                  size: 2\n            "
                    ],
                    "items": {
                        "$ref": "#/$defs/Panel"
                    },
                    "title": "Panels",
                    "type": "array"
                }
            },
            "required": [
                "name",
                "panels"
            ],
            "title": "Row",
            "type": "object"
        },
        "ScheduledQuery": {
            "properties": {
                "name": {
                    "description": "The name of the scheduled query.",
                    "examples": [
                        "Recently published HIGH/CRITICAL CVEs"
                    ],
                    "title": "Name",
                    "type": "string"
                },
                "cypher": {
                    "description": "The cypher to use for the scheduled query.",
                    "examples": [
                        "recent-cves"
                    ],
                    "title": "Cypher",
                    "type": "string"
                },
                "params": {
                    "description": "A dictionary of parameters to pass to the cypher query. The keys are the variable names, and the values are the values to pass.",
                    "examples": [
                        "\n            .. code-block:: yaml\n\n              params:\n                - name: syncedtype\n                  value:\n                    - recent\n                - name: base_severity\n                  value:\n                    - HIGH\n                    - CRITICAL\n            "
                    ],
                    "items": {
                        "$ref": "#/$defs/ScheduledQueryParam"
                    },
                    "title": "Params",
                    "type": "array"
                },
                "frequency": {
                    "anyOf": [
                        {
                            "type": "integer"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "The frequency of the scheduled query in minutes. Mutually exclusive with ``watch_scans``.",
                    "examples": [
                        "1440"
                    ],
                    "title": "Frequency"
                },
                "watch_scans": {
                    "description": "The scans to watch for the scheduled query. Based on SyncMetadata. Query will triger if any of the watched scans listed are updated. Mutually exclusive with ``frequency``.",
                    "examples": [
                        "\n            .. code-block:: yaml\n\n              watch_scans:\n                - grouptype: CVE\n                  syncedtype: recent\n                - grouptype: CVE\n                  syncedtype: modified\n            "
                    ],
                    "items": {
                        "$ref": "#/$defs/ScheduledQueryWatchScan"
                    },
                    "title": "Watch Scans",
                    "type": "array"
                },
                "enabled": {
                    "anyOf": [
                        {
                            "type": "boolean"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": true,
                    "description": "Whether the scheduled query should be enabled. If not set, the scheduled query will be enabled.",
                    "examples": [
                        "true"
                    ],
                    "title": "Enabled"
                },
                "actions": {
                    "description": "The actions to perform when the scheduled query is triggered.",
                    "examples": [
                        "\n            .. code-block:: yaml\n\n              actions:\n                - action_type: slack\n                  title: Recently published HIGH/CRITICAL CVEs\n                  initial_comment: |\n                    The following HIGH/CRITICAL CVEs have been published in the last 24 hours.\n                  channels:\n                    - C0000000000\n            "
                    ],
                    "items": {
                        "$ref": "#/$defs/ScheduledQueryAction"
                    },
                    "title": "Actions",
                    "type": "array"
                }
            },
            "required": [
                "name",
                "cypher"
            ],
            "title": "ScheduledQuery",
            "type": "object"
        },
        "ScheduledQueryAction": {
            "properties": {
                "action_type": {
                    "description": "The type of action to perform.",
                    "examples": [
                        "slack",
                        "sqs"
                    ],
                    "title": "Action Type",
                    "type": "string"
                },
                "action_config": {
                    "additionalProperties": true,
                    "description": "The configuration for the action. See the documentation for the relevant scheduled query module for information about the configuration needed for each action type.",
                    "examples": [
                        "\n            .. code-block:: yaml\n\n              action_config:\n                webhook_url: https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXXXXXX\n                channel: #cve\n                username: CVE\n                icon_emoji: :cve:\n            "
                    ],
                    "title": "Action Config",
                    "type": "object"
                }
            },
            "required": [
                "action_type",
                "action_config"
            ],
            "title": "ScheduledQueryAction",
            "type": "object"
        },
        "ScheduledQueryParam": {
            "properties": {
                "name": {
                    "description": "The parameter name to use when passing this input into the query.",
                    "examples": [
                        "severity"
                    ],
                    "title": "Name",
                    "type": "string"
                },
                "value": {
                    "description": "The parameter value to pass into the query.",
                    "examples": [
                        "\n            .. code-block:: yaml\n\n              params:\n                - name: integrityImpact\n                  value: HIGH\n            "
                    ],
                    "title": "Value"
                }
            },
            "required": [
                "name",
                "value"
            ],
            "title": "ScheduledQueryParam",
            "type": "object"
        },
        "ScheduledQueryWatchScan": {
            "properties": {
                "grouptype": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": ".*",
                    "description": "Match against the grouptype attribute of the SyncMetadata node, as a regex. If not set, the query will match against ``.*``.",
                    "examples": [
                        "CVE"
                    ],
                    "title": "Grouptype"
                },
                "syncedtype": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": ".*",
                    "description": "Match against the syncedtype attribute of the SyncMetadata node, as a regex. If not set, the query will match against ``.*``.",
                    "examples": [
                        "year"
                    ],
                    "title": "Syncedtype"
                },
                "groupid": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": ".*",
                    "description": "Match against the groupid attribute of the SyncMetadata node, as a regex. If not set, the query will match against ``.*``.",
                    "examples": [
                        "2019"
                    ],
                    "title": "Groupid"
                }
            },
            "title": "ScheduledQueryWatchScan",
            "type": "object"
        },
        "SkillDef": {
            "description": "A prompt template definition within a skillset.",
            "properties": {
                "name": {
                    "title": "Name",
                    "type": "string"
                },
                "description": {
                    "default": "",
                    "title": "Description",
